# Worker de transcrição (worker-transcription) — variáveis de ambiente.
# Copie para .env e preencha. Segredos NUNCA vão para o código/repo.

# Porta HTTP do worker Go.
PORT=8770

# Autentica o cliente -> worker Go (header X-API-Key). OBRIGATÓRIO.
API_KEY=

# Conexão Redis (fila + estado).
REDIS_URL=redis://localhost:6379/0

# Whisper hospedado (destino do repasse).
WHISPER_UPSTREAM_URL=https://whisper.lai.ia.br
# API key enviada ao Whisper (header X-API-Key). OBRIGATÓRIO.
WHISPER_API_KEY=

# Goroutines que processam jobs em paralelo (downloads/preparo). A chamada ao
# Whisper é sempre serializada (1 por vez) por um gate interno, então isto NÃO
# aumenta a carga simultânea na GPU — só o paralelismo de download/preparo.
MAX_CONCURRENCY=2

# Profundidade máxima da fila antes de responder 429.
QUEUE_SIZE=100

# TTL do resultado/estado no Redis (ex.: 1h, 30m, 600s).
JOB_TTL=1h

# Tamanho máximo de upload/download em bytes (default 100 MB).
MAX_AUDIO_BYTES=104857600

# Timeout do download por URL.
DOWNLOAD_TIMEOUT=600s

# Timeout da chamada ao Whisper.
UPSTREAM_TIMEOUT=600s

# Idioma default (ISO 639-1) quando não informado.
DEFAULT_LANGUAGE=pt
